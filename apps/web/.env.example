# PostgreSQL — stejný formát na Vercelu i lokálně (Docker / Neon / jiný host).
# Příklad lokálně: postgresql://USER:PASSWORD@localhost:5432/mott_dev?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mott_dev?schema=public"
# Optional guard for POST /api/reclassify (dev only):
# RECLASSIFY_TOKEN="set-some-random-string"
# Pilot komerčních agregátorů:
# INGEST_PILOT_MAX_ITEMS=120
# INGEST_PILOT_THROTTLE_MS=0
# Vypnutí pilotního Geminu (zbytek pilotů zůstává):
# INGEST_PILOT_DISABLE_GEMIN=1
# E‑ZAK: výchozí je dotáhnout z HTML detailu vždy (datum + lhůta). Úspora HTTP: jen chyběící lhůta z přehledu:
# INGEST_EZAK_DETAIL_ENRICH=deadline
# Vypnout dotahování detailu E‑ZAK úplně: INGEST_EZAK_DETAIL_DEADLINE=0

# Stabilita ingestu (429 / timeout):
# Globální max. současných HTTP požadavků napříč všemi zdroji ingestu (fetchWithTimeout). 0 = bez limitu.
# INGEST_OUTBOUND_CONCURRENCY=4
# Per-host limit uvnitř fetchWithTimeout (výchozí 2; pro rizikové hosty viz níže)
# INGEST_OUTBOUND_PER_HOST_CONCURRENCY=2
# Per-host limit pro rizikové hosty (TenderArena/eGORDION/NEN)
# INGEST_OUTBOUND_RISKY_HOST_CONCURRENCY=1
# Minimální rozestup requestů na stejný host (ms)
# INGEST_HOST_MIN_INTERVAL_MS=250
# Minimální rozestup pro rizikové hosty — TenderArena/eGORDION/NEN (ms, výchozí 2000):
# INGEST_RISKY_HOST_MIN_INTERVAL_MS=2000
# Cooldown po 429 bez Retry-After (ms) + jitter
# INGEST_429_COOLDOWN_MS=30000
# INGEST_429_COOLDOWN_JITTER_MS=15000
# Fázovaný sběr zdrojů (omezí špičky paralelity): 1=zapnuto, 0=vypnuto
# INGEST_PHASED_FETCH=1
# Délka lookback okna XML profilů (měsíce)
# INGEST_LOOKBACK_MONTHS=12
# Timeout pro NEN XML (ms)
# INGEST_NEN_FETCH_TIMEOUT_MS=30000
# NEN XML concurrency (nižší = stabilnější, pomalejší)
# INGEST_NEN_CONCURRENCY=2
# Retry po timeout/abort u NEN XML
# INGEST_NEN_ABORT_RETRY=1
# INGEST_NEN_ABORT_RETRY_MAX=1
# INGEST_NEN_ABORT_RETRY_BACKOFF_MS=1500
# INGEST_NEN_ABORT_TIMEOUT_STEP_MS=10000
# INGEST_NEN_ABORT_TIMEOUT_MAX_MS=60000
# Retry při HTTP 429 na XML profilech
# INGEST_XML_RETRY_429_MAX=3
# INGEST_XML_RETRY_429_BACKOFF_MS=1500
# INGEST_XML_RETRY_429_JITTER_MS=500
# INGEST_XML_RETRY_429_MAX_WAIT_MS=120000
# Concurrency generických XML profilů (TenderArena/eGORDION/PROEBIZ…)
# INGEST_XML_PROFILE_CONCURRENCY=2

# Proxy pilot (fallback pouze pro hosty s trvale vysokým 429):
# INGEST_PROXY_PILOT_ENABLED=0
# INGEST_PROXY_PILOT_HOSTS=tenderarena.cz,egordion.cz
# INGEST_PROXY_PILOT_TRIGGER_429_RATE=0.2
# URL proxy serveru (Smartproxy/Bright Data) — inicializuje undici ProxyAgent:
# INGEST_PROXY_URL=http://user:pass@gate.smartproxy.com:10001

# Domain-wide 429 circuit breaker — po N po sobě jdoucích 429 na hostu se zbylé zdroje přeskočí:
# INGEST_HOST_429_CONSECUTIVE_THRESHOLD=5
# Cooldown před retry roundem po 429-selhání (ms, výchozí 60000 = 60s):
# INGEST_XML_429_RETRY_ROUND_COOLDOWN_MS=60000

# Hlídač státu API (fallback/validační zdroj pro NEN a TenderArena):
# Token získáte na https://www.hlidacstatu.cz/api — bez tokenu se konektor přeskočí.
# HLIDAC_STATU_API_TOKEN=docela1dlouhy2token3pro4tohleHS5api
# Timeout jednoho požadavku na Hlídač státu (ms):
# INGEST_HLIDAC_FETCH_TIMEOUT_MS=12000
# Max souběžných ICO dotazů na Hlídač státu:
# INGEST_HLIDAC_CONCURRENCY=2
# Max stránek na jedno ICO (1 stránka = 50 záznamů):
# INGEST_HLIDAC_MAX_PAGES=5
