{
  "name": "@mott/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "node ./scripts/generate.mjs",
    "migrate": "node ./scripts/migrate-dev.mjs",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.postgres.prisma",
    "migrate:deploy:if-env": "node ./scripts/migrate-deploy-if-env.mjs",
    "studio": "prisma studio --schema=./prisma/sqlite/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2"
  },
  "devDependencies": {
    "prisma": "^6.8.2"
  }
}
