{
  "name": "@mott/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node scripts/clean-next.mjs",
    "dev": "node scripts/run-dev.mjs",
    "dev:clean": "node scripts/clean-next.mjs && node scripts/run-dev.mjs",
    "build": "npm run db:generate --prefix ../.. && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "check-ingest-urls": "node scripts/check-ingest-source-urls.mjs",
    "ingest:run": "tsx scripts/run-ingest.ts"
  },
  "dependencies": {
    "@mott/db": "*",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^5.6.0",
    "jose": "^6.2.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "undici": "^7.24.7",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xml2js": "^0.4.14",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
